# Normalização de fim de linha — o repo é editado no Windows e no macOS.
* text=auto

# Scripts bash PRECISAM de LF (CRLF quebra o shebang/execução no macOS)
*.sh text eol=lf

# PowerShell prefere CRLF
*.ps1 text eol=crlf

# Texto e código: LF
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binários
*.png binary
*.jpg binary
*.gif binary
*.woff* binary
